const tiles=L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19,opacity:OSM_OPACITY,attribution:'&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'}).addTo(map);
tiles.on('tileerror',()=>document.getElementById('notice').style.display='block');

// Extra layers (below GPX tracks) — track each layer so we can show/hide them in the layers panel
const EX=[{"type":"xyz","url":"https://wms.prod.qgiscloud.com/PeeWee32/brouter_layers?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=surface2&FORMAT=image/png&TILEMATRIXSET=EPSG:3857&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}","wmsLayer":"","displayName":"surface","opacity":0.8,"zoomMin":1,"zoomMax":22,"defaultOn":true},{"type":"xyz","url":"https://wms.prod.qgiscloud.com/PeeWee32/test?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=verkeerdrempel_missing&FORMAT=image/png&TILEMATRIXSET=EPSG:3857&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}","wmsLayer":"","displayName":"drempel","opacity":0.8,"zoomMin":15,"zoomMax":22,"defaultOn":true}];
const wmsLayerObjs=[];
EX.forEach((el,i)=>{
  let lyr=null;
  try{
    if(el.type==='wms'){
      lyr=L.tileLayer.wms(el.url,{layers:el.wmsLayer,format:'image/png',transparent:true,opacity:el.opacity,attribution:'',minZoom:el.zoomMin,maxZoom:el.zoomMax});
    } else {
      lyr=L.tileLayer(el.url,{opacity:el.opacity,attribution:'',minZoom:el.zoomMin,maxZoom:el.zoomMax});
    }
    // standaard aan/uit: uit URL-status indien aanwezig, anders uit de instelling van de laag zelf
    const defaultOn=(urlState&&urlState.layerVis&&urlState.layerVis[i]!=null)?urlState.layerVis[i]:(el.defaultOn!==false);
    if(defaultOn) lyr.addTo(map);
  }catch(e){}
  wmsLayerObjs.push({layer:lyr,name:el.displayName||('Laag '+(i+1)),visible:true});
});

// Layers panel top-right: only show if there are extra layers
if(EX.length>0){
  const layersBtn=document.getElementById('layers-btn');
  const layersOverlay=document.getElementById('layers-overlay');
  const layersPanel=document.getElementById('layers-panel');
  const panelContent=document.getElementById('layers-panel-content');
  layersOverlay.style.display='block';
  wmsLayerObjs.forEach((lo,i)=>{
    const row=document.createElement('label');
    row.className='layer-toggle-row';
    const isOn=lo.layer&&map.hasLayer(lo.layer);
    row.innerHTML='<input type="checkbox" '+(isOn?'checked':'')+' data-idx="'+i+'"><span>'+lo.name+'</span>';
    panelContent.appendChild(row);
  });
  panelContent.querySelectorAll('input').forEach(inp=>{
    inp.addEventListener('change',e=>{
      const i=parseInt(e.target.dataset.idx);
      const lo=wmsLayerObjs[i];
      if(!lo.layer)return;
      if(e.target.checked){map.addLayer(lo.layer);}else{map.removeLayer(lo.layer);}
      updateUrlHash();
    });
  });
  layersBtn.onclick=function(){layersPanel.classList.toggle('open');};
  document.addEventListener('click',function(e){
    if(!layersOverlay.contains(e.target))layersPanel.classList.remove('open');
  });
} else {
  document.getElementById('layers-overlay').style.display='none';
}

const labelLayers=[];
const trackLayers=[];
const wptMarkerLayers=[];

D.forEach(f=>{
  const filePolys=[];
  const fLw=f.lineWidth!=null?f.lineWidth:3;
  const fZMin=f.mapZoomMin!=null?f.mapZoomMin:1;
  const fZMax=f.mapZoomMax!=null?f.mapZoomMax:MAX_ZOOM;
  f.tracks.forEach(t=>{
    const poly=L.polyline(t.coords,{color:f.color,weight:fLw,opacity:.9}).addTo(map);
    poly.bindPopup('<b>'+getLabelText(f,t.name)+'</b>'+(t.name?'<br>'+t.name:''));
    poly._gpxFile=f;
    poly._trackZoomMin=fZMin;
    poly._trackZoomMax=fZMax;
    trackLayers.push(poly);
    wptMarkerLayers.push(poly); // same zoom-visibility mechanism as waypoint markers
    filePolys.push(poly);
  });
  if(f.showStart&&f.tracks.length&&f.tracks[0].coords.length){
    const sp=f.tracks[0].coords[0];
    const startM=L.marker(sp,{
      icon:L.divIcon({
        className:'',
        html:'<div style="width:22px;height:22px;background:'+f.color+';border:2px solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.4)"><span style="color:#fff;font-size:11px;line-height:1;margin-left:2px">&#9654;</span></div>',
        iconSize:[22,22],iconAnchor:[11,11]
      }),
      interactive:false,zIndexOffset:300
    }).addTo(map);
    startM._trackZoomMin=fZMin;
    startM._trackZoomMax=fZMax;
    trackLayers.push(startM);
    wptMarkerLayers.push(startM);
  }
  // KM direction markers: every kilometer along the combined tracks of this GPX
  if(f.showKmMarkers&&f.tracks.length){
    const allTrackCoords=f.tracks.flatMap(t=>t.coords);
    const kmMarkers=buildKmMarkers(allTrackCoords);
    kmMarkers.forEach(km=>{
      const kmM=L.marker(km.position,{
        icon:L.divIcon({
          className:'',
          html:'<svg width="26" height="26" viewBox="0 0 26 26" style="transform:rotate('+km.bearing+'deg);filter:drop-shadow(0 1px 3px rgba(0,0,0,.5))"><polygon points="13,2 19,22 13,17 7,22" fill="'+f.color+'" stroke="#fff" stroke-width="1.5" stroke-linejoin="round"/></svg>',
          iconSize:[26,26],iconAnchor:[13,13]
        }),
        zIndexOffset:180
      }).addTo(map);
      kmM.bindPopup('<b>'+km.km+' km</b>');
      kmM._trackZoomMin=fZMin;
      kmM._trackZoomMax=fZMax;
      trackLayers.push(kmM);
      wptMarkerLayers.push(kmM);
    });
  }
  f.waypoints.forEach(w=>{
    const m=buildWaypointMarker(f,w).addTo(map);
    const wLabel=getLabelText(f,w.name);
    if(w.name||w.desc)m.bindPopup('<b>'+wLabel+'</b>'+(w.desc?'<br>'+w.desc:''));
    // narrowest (strictest) range of global waypoint-marker-zoom and this GPX's map zoom
    m._trackZoomMin=Math.max(WPTMARKERZOOM,fZMin);
    m._trackZoomMax=fZMax;
    trackLayers.push(m);
    wptMarkerLayers.push(m);
    // waypoint label: only if showLabel is on for this GPX, zoomdrempel uit globale WPTZOOM
    if(f.showLabel){
      const h=contrastHalo(f.color);
      const wptLbl=L.marker([w.lat,w.lon],{
        icon:L.divIcon({
          className:'',
          html:'<div style="color:'+f.color+';font-size:20px;font-weight:600;white-space:nowrap;pointer-events:none;text-shadow:-2.3px -2.3px 0 '+h+',2.3px -2.3px 0 '+h+',-2.3px 2.3px 0 '+h+',2.3px 2.3px 0 '+h+',0 2.3px 0 '+h+',0 -2.3px 0 '+h+';transform:translate(-50%,calc(-50% - 18px))">'+wLabel+'</div>',
          iconAnchor:[0,0]
        }),
        interactive:false,zIndexOffset:150
      }).addTo(map);
      wptLbl._zoomMin=WPTZOOM;
      wptLbl._zoomMax=19;
      labelLayers.push(wptLbl);
    }
  });
  if(f.showLabel&&f.tracks.length){
    const h=contrastHalo(f.color);
    const mainLabel=getLabelText(f,f.tracks[0].name);
    if(f.labelPos==='midline'&&f.tracks.length){
      const simplified=buildTextPathLine(f.tracks[0].coords, mainLabel.length);
      const textPoly=L.polyline(simplified,{opacity:0,weight:1}).addTo(map);
      textPoly.setText(mainLabel,{center:true,repeat:false,attributes:{'font-size':'24px','font-weight':'bold','fill':f.color,'paint-order':'stroke','stroke':h,'stroke-width':'3px','stroke-linejoin':'round'}});
      textPoly._gpxFile=f;
      textPoly._zoomMin=f.labelZoomMin;
      textPoly._zoomMax=f.labelZoomMax;
      labelLayers.push(textPoly);
    } else {
      const allPts=f.tracks.flatMap(t=>t.coords);
      let pos;
      if(f.labelPos==='start') pos=f.tracks[0].coords[0];
      else pos=labelAnchorCentroid(allPts);
      const labelOffset=(f.labelPos==='start'&&f.showStart)?'transform:translate(-50%,calc(-50% - 18px))':'transform:translate(-50%,-50%)';
      const lbl=L.marker(pos,{
        icon:L.divIcon({
          className:'',
          html:'<div style="color:'+f.color+';font-size:32px;font-weight:700;white-space:nowrap;pointer-events:none;text-shadow:-3px -3px 0 '+h+',3px -3px 0 '+h+',-3px 3px 0 '+h+',3px 3px 0 '+h+',0 3px 0 '+h+',0 -3px 0 '+h+',3px 0 0 '+h+',-3px 0 0 '+h+';'+labelOffset+'">'+mainLabel+'</div>',
          iconAnchor:[0,0]
        }),
        interactive:false,zIndexOffset:200
      }).addTo(map);
      lbl._zoomMin=f.labelZoomMin;
      lbl._zoomMax=f.labelZoomMax;
      labelLayers.push(lbl);
    }
  }
});

if(urlState&&urlState.z!=null){
  map.setView([urlState.lat,urlState.lng],urlState.z);
} else if(B){
  map.fitBounds(B,{padding:[16,16]});
} else {
  map.setView([52,5],8);
}

// Update URL on every pan/zoom so the address bar always reflects the current map state (shareable)
map.on('moveend',updateUrlHash);

function updateLabels(){
  const z=map.getZoom();
  labelLayers.forEach(l=>{
    const visible=z>=l._zoomMin&&z<=l._zoomMax;
    if(l.setText){
      if(visible){
        const f=l._gpxFile;
        const h=contrastHalo(f.color);
        const mainLabel=getLabelText(f,f.tracks[0]&&f.tracks[0].name);
        l.setText(null);l.setText(mainLabel,{center:true,repeat:false,attributes:{'font-size':'24px','font-weight':'bold','fill':f.color,'paint-order':'stroke','stroke':h,'stroke-width':'3px','stroke-linejoin':'round'}});
      } else { l.setText(null); }
    } else {
      const e=l.getElement();if(e)e.style.display=visible?'':'none';
    }
  });
  wptMarkerLayers.forEach(m=>{
    const visible=z>=m._trackZoomMin&&z<=m._trackZoomMax;
    const e=m.getElement();
    if(e)e.style.display=visible?'':'none';
  });
}
map.on('zoomend',updateLabels);
map.whenReady(updateLabels);

// Zoomniveau-indicator rechtsboven
const zoomValEl=document.getElementById('zoom-val');
function updateZoomIndicator(){zoomValEl.textContent=map.getZoom();}
map.on('zoomend',updateZoomIndicator);
map.whenReady(updateZoomIndicator);

// --- Locatie en volgen ---
const locBtn=document.getElementById('loc-btn');
const visBtn=document.getElementById('vis-btn');
let wid=null,locTrail=null,lc=null,dirMarker=null;
let followZoom=null; // fixed zoom level at start of following, prevents jitter from getZoom() during animation
let locHistory=[]; // GPS points for direction trail (distance-based trimming, see trimTrail)
const TRAIL_MODE="distance"; // 'distance' of 'full'
const TRAIL_METERS=500;
const FOLLOW_RESUME_DELAY=5000; // ms to wait after last manual map interaction before auto-centering again
let lastUserInteraction=0; // timestamp of last manual pan/zoom
let programmaticMove=false; // flag to distinguish our own setView calls from user interaction

function haversineMeters(p1,p2){
  const R=6371000;
  const lat1=p1[0]*Math.PI/180, lat2=p2[0]*Math.PI/180;
  const dLat=(p2[0]-p1[0])*Math.PI/180, dLon=(p2[1]-p1[1])*Math.PI/180;
  const a=Math.sin(dLat/2)**2+Math.cos(lat1)*Math.cos(lat2)*Math.sin(dLon/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}

// Trim the trail: with 'full' everything is kept (whole ride, even after 50km), with 'distance'
// only the points within the last TRAIL_METERS meters (measured along the path) are kept.
function trimTrail(history){
  if(TRAIL_MODE==='full' || history.length<2) return history;
  let acc=0;
  let cutIdx=0;
  for(let i=history.length-1;i>0;i--){
    acc+=haversineMeters(history[i-1],history[i]);
    if(acc>=TRAIL_METERS){ cutIdx=i-1; break; }
    cutIdx=0;
  }
  return history.slice(cutIdx);
}

function bearing(p1,p2){
  // peiling in graden van p1 naar p2 (0=noord)
  const lat1=p1[0]*Math.PI/180, lat2=p2[0]*Math.PI/180;
  const dLon=(p2[1]-p1[1])*Math.PI/180;
  const y=Math.sin(dLon)*Math.cos(lat2);
  const x=Math.cos(lat1)*Math.sin(lat2)-Math.sin(lat1)*Math.cos(lat2)*Math.cos(dLon);
  return (Math.atan2(y,x)*180/Math.PI+360)%360;
}

// Pointed triangle as SVG: rotation center exactly at the center of the shape, no skewed rendering
function makeDirIcon(deg){
  return L.divIcon({
    className:'',
    html:'<svg width="46" height="46" viewBox="0 0 46 46" style="transform:rotate('+deg+'deg);filter:drop-shadow(0 1px 2px rgba(0,0,0,.5))">'
        +'<polygon points="23,2 31,39 23,29 15,39" fill="'+TRAIL_COLOR+'" stroke="#fff" stroke-width="2.5" stroke-linejoin="round"/>'
        +'</svg>',
    iconSize:[46,46],
    iconAnchor:[23,23]
  });
}

function stopLoc(){
  if(wid!==null){navigator.geolocation.clearWatch(wid);wid=null;}
  locBtn.classList.remove('on');locBtn.innerHTML='&#9737;';
  if(locTrail){map.removeLayer(locTrail);locTrail=null;}
  if(lc){map.removeLayer(lc);lc=null;}
  if(dirMarker){map.removeLayer(dirMarker);dirMarker=null;}
  followZoom=null;
  locHistory=[];
}

// Detect manual map interaction (drag/zoom by user) to temporarily pause auto-centering
map.on('dragstart zoomstart',function(){
  if(!programmaticMove) lastUserInteraction=Date.now();
});

locBtn.onclick=function(){
  if(wid!==null){stopLoc();return;}
  if(!navigator.geolocation){alert('GPS is not available in this browser.');return;}
  locBtn.innerHTML='&#8987;';

  wid=navigator.geolocation.watchPosition(function(p){
    const ll=[p.coords.latitude,p.coords.longitude];
    locBtn.classList.add('on');locBtn.innerHTML='&#9737;';

    // update trail: with 'distance' only keep last X meters, with 'full' keep everything
    locHistory.push(ll);
    locHistory=trimTrail(locHistory);

    // determine bearing: use GPS heading if available, otherwise compute from trail
    let deg=0;
    if(p.coords.heading!=null && !isNaN(p.coords.heading)){
      deg=p.coords.heading;
    } else if(locHistory.length>=2){
      deg=bearing(locHistory[0],locHistory[locHistory.length-1]);
    }

    if(locTrail){
      locTrail.setLatLngs(locHistory);
      lc.setLatLng(ll).setRadius(p.coords.accuracy);
      dirMarker.setLatLng(ll).setIcon(makeDirIcon(deg));
    } else {
      lc=L.circle(ll,{radius:p.coords.accuracy,color:TRAIL_COLOR,fillColor:TRAIL_COLOR,fillOpacity:.12,weight:1}).addTo(map);
      locTrail=L.polyline(locHistory,{color:TRAIL_COLOR,weight:TRAIL_WIDTH,opacity:.85,lineCap:'round'}).addTo(map);
      dirMarker=L.marker(ll,{icon:makeDirIcon(deg),interactive:false,zIndexOffset:500}).addTo(map).bindPopup('Your location');
    }

    const idleLongEnough=(Date.now()-lastUserInteraction)>=FOLLOW_RESUME_DELAY;

    if(OPT_FOLLOW && idleLongEnough){
      // lock zoom level once at start of following, don't re-query during animation
      if(followZoom===null) followZoom=Math.max(map.getZoom(),16);
      programmaticMove=true;
      map.setView(ll, followZoom, {animate:false});
      programmaticMove=false;
    } else if(!dirMarker._shown){
      programmaticMove=true;
      map.setView(ll, Math.max(map.getZoom(),16));
      programmaticMove=false;
      dirMarker._shown=true;
    }
  },function(e){
    stopLoc();
    alert('Location unavailable: '+e.message);
  },{enableHighAccuracy:true,maximumAge:1000});
};

// If user manually zooms while following is active, remember new zoom level instead of snapping back
map.on('zoomend',function(){
  if(OPT_FOLLOW && wid!==null) followZoom=map.getZoom();
});

let gpxVisible=true;
visBtn.onclick=function(){
  gpxVisible=!gpxVisible;
  trackLayers.forEach(l=>{
    if(gpxVisible)map.addLayer(l);else map.removeLayer(l);
  });
  labelLayers.forEach(l=>{
    if(gpxVisible){map.addLayer(l);}else map.removeLayer(l);
  });
  if(gpxVisible)updateLabels();
  visBtn.style.opacity=gpxVisible?'1':'0.5';
};
</script>
