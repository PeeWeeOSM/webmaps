function centroid(coords){
  if(!coords.length)return[0,0];
  let la=0,lo=0;
  coords.forEach(p=>{la+=p[0];lo+=p[1];});
  return[la/coords.length,lo/coords.length];
}

function nearestPointOnLine(point, lineCoords){
  if(lineCoords.length===0) return point;
  if(lineCoords.length===1) return lineCoords[0];
  let best=lineCoords[0], bestDist=Infinity;
  for(let i=0;i<lineCoords.length-1;i++){
    const a=lineCoords[i], b=lineCoords[i+1];
    const dx=b[0]-a[0], dy=b[1]-a[1];
    let t = (dx===0&&dy===0) ? 0 : ((point[0]-a[0])*dx+(point[1]-a[1])*dy)/(dx*dx+dy*dy);
    t = Math.max(0, Math.min(1, t));
    const proj=[a[0]+t*dx, a[1]+t*dy];
    const d=Math.hypot(point[0]-proj[0], point[1]-proj[1]);
    if(d<bestDist){ bestDist=d; best=proj; }
  }
  return best;
}

function labelAnchorCentroid(trackCoords){
  const c=centroid(trackCoords);
  return nearestPointOnLine(c, trackCoords);
}

function bearingPoints(p1,p2){
  const lat1=p1[0]*Math.PI/180, lat2=p2[0]*Math.PI/180;
  const dLon=(p2[1]-p1[1])*Math.PI/180;
  const y=Math.sin(dLon)*Math.cos(lat2);
  const x=Math.cos(lat1)*Math.sin(lat2)-Math.sin(lat1)*Math.cos(lat2)*Math.cos(dLon);
  return (Math.atan2(y,x)*180/Math.PI+360)%360;
}

function buildKmMarkers(coords){
  if(coords.length<2) return [];
  const markers=[];
  let cumDist=0;
  let nextKm=1000;
  for(let i=0;i<coords.length-1;i++){
    const segDist=haversineMeters(coords[i],coords[i+1]);
    while(cumDist+segDist>=nextKm){
      const t=(nextKm-cumDist)/segDist;
      const lat=coords[i][0]+t*(coords[i+1][0]-coords[i][0]);
      const lon=coords[i][1]+t*(coords[i+1][1]-coords[i][1]);
      markers.push({position:[lat,lon], bearing:bearingPoints(coords[i],coords[i+1]), km:nextKm/1000});
      nextKm+=1000;
    }
    cumDist+=segDist;
  }
  return markers;
}

function simplifyLine(points, tolerance){
  if(points.length<3) return points;
  function perpDist(pt,a,b){
    const dx=b[0]-a[0], dy=b[1]-a[1];
    if(dx===0&&dy===0) return Math.hypot(pt[0]-a[0],pt[1]-a[1]);
    const t=((pt[0]-a[0])*dx+(pt[1]-a[1])*dy)/(dx*dx+dy*dy);
    const tc=Math.max(0,Math.min(1,t));
    const px=a[0]+tc*dx, py=a[1]+tc*dy;
    return Math.hypot(pt[0]-px,pt[1]-py);
  }
  function dp(pts,tol){
    if(pts.length<3) return pts;
    let maxD=0,idx=0;
    for(let i=1;i<pts.length-1;i++){
      const d=perpDist(pts[i],pts[0],pts[pts.length-1]);
      if(d>maxD){maxD=d;idx=i;}
    }
    if(maxD>tol){
      const left=dp(pts.slice(0,idx+1),tol);
      const right=dp(pts.slice(idx),tol);
      return left.slice(0,-1).concat(right);
    }
    return [pts[0],pts[pts.length-1]];
  }
  return dp(points,tolerance);
}

function buildTextPathLine(coords, labelLength){
  if(coords.length<3) return normalizeDirection(coords);
  const lats=coords.map(p=>p[0]), lons=coords.map(p=>p[1]);
  const span=Math.max(Math.max(...lats)-Math.min(...lats), Math.max(...lons)-Math.min(...lons));
  const lenFactor = labelLength ? Math.max(0.4, 1-(labelLength-10)*0.03) : 1;
  const tolerance=Math.max(span*0.012*lenFactor, 0.00008);
  const simplified=simplifyLine(coords, tolerance);
  return normalizeDirection(simplified);
}

function normalizeDirection(coords){
  if(coords.length<2) return coords;
  const start=coords[0], end=coords[coords.length-1];
  const dLon=end[1]-start[1];
  const dLat=end[0]-start[0];
  const goingLeft = Math.abs(dLon) >= Math.abs(dLat) ? dLon < 0 : dLat < 0;
  return goingLeft ? coords.slice().reverse() : coords;
}

function contrastHalo(hex){
  const r=parseInt(hex.slice(1,3),16);
  const g=parseInt(hex.slice(3,5),16);
  const b=parseInt(hex.slice(5,7),16);
  return(0.299*r+0.587*g+0.114*b)>140?'#000':'#fff';
}

